<Window x:Class="AlarmApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AlarmApp.ViewModels"
        xmlns:converters="clr-namespace:AlarmApp.Converters"
        Title="Timer App" Width="580"
        MinHeight="150" MinWidth="400"
        SizeToContent="Height"
        FocusManager.FocusedElement="{Binding ElementName=MinutesBox}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Key="Return" Command="{Binding AddTimerCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Add Timer Panel -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Hours:" VerticalAlignment="Center" Margin="0,0,5,0" />
                <TextBox x:Name="HoursBox" Text="{Binding Hours, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', FallbackValue=''}"
                         Width="40" VerticalAlignment="Center" TextAlignment="Center"
                         GotFocus="TextBox_GotFocus" PreviewTextInput="NumberBox_PreviewTextInput" />

                <TextBlock Text="Minutes:" VerticalAlignment="Center" Margin="15,0,5,0" />
                <TextBox x:Name="MinutesBox" Text="{Binding Minutes, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', FallbackValue=''}"
                         Width="40" VerticalAlignment="Center" TextAlignment="Center"
                         GotFocus="TextBox_GotFocus" PreviewTextInput="NumberBox_PreviewTextInput" />

                <TextBlock Text="Seconds:" VerticalAlignment="Center" Margin="15,0,5,0" />
                <TextBox x:Name="SecondsBox" Text="{Binding Seconds, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', FallbackValue=''}"
                         Width="40" VerticalAlignment="Center" TextAlignment="Center"
                         GotFocus="TextBox_GotFocus" PreviewTextInput="NumberBox_PreviewTextInput" />

                <Button Content="Add Timer" Command="{Binding AddTimerCommand}"
                        Margin="20,0,0,0" Padding="15,5" />
            </StackPanel>
        </Border>

        <!-- Timer List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Timers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,5" Padding="8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Background" Value="LimeGreen" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRinging}" Value="True">
                                            <Setter Property="Background" Value="OrangeRed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Height="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" MinWidth="160" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>

                                <!-- Remaining Time -->
                                <TextBlock Grid.Column="0" Text="{Binding RemainingDisplay}"
                                           FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />

                                <!-- Original Duration -->
                                <TextBlock Grid.Column="1" Text="{Binding OriginalDisplay}"
                                           Foreground="Gray" VerticalAlignment="Center" />

                                <!-- Alarm Duration + Loop -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Alarm:" Margin="0,0,5,0" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding AlarmDurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                                             Width="30" TextAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Text="s" Margin="2,0,8,0" VerticalAlignment="Center" />
                                    <CheckBox Content="Loop" IsChecked="{Binding IsLooping}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding LoopCount, StringFormat='×{0}'}" Margin="4,0,0,0"
                                               VerticalAlignment="Center" Foreground="Gray">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLooping}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Start/Pause Button -->
                                <Button Grid.Column="3" Content="{Binding StartPauseWithShortcut}"
                                        Command="{Binding DataContext.StartPauseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Margin="5,0" />

                                <!-- Reset Button -->
                                <Button Grid.Column="4" Content="Reset"
                                        Command="{Binding DataContext.ResetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Margin="5,0" />

                                <!-- Delete Button -->
                                <Button Grid.Column="5" Content="Delete"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
